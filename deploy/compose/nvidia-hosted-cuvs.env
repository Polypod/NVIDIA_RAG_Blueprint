# ==========================
# NVIDIA RAG Blueprint - NVIDIA API Catalog Hosted NIMs with cuVS Vector DB
# ==========================
# This configuration uses NVIDIA-hosted NIM microservices via the NVIDIA API Catalog
# with a cuVS-accelerated vector database requiring only 1 GPU.
#
# Usage:
#   source deploy/compose/nvidia-hosted-cuvs.env
#   docker compose -f deploy/compose/vectordb.yaml up -d
#   docker compose -f deploy/compose/docker-compose-ingestor-server.yaml up -d
#   docker compose -f deploy/compose/docker-compose-rag-server.yaml up -d
#
# Prerequisites:
# - NVIDIA API Key (get from https://build.nvidia.com/)
# - Docker with NVIDIA Container Toolkit
# - 1 GPU for cuVS-accelerated Milvus vector database
# ==========================

# ==========================
# User / Auth
# ==========================
export USERID=$(id -u)
export NVIDIA_API_KEY=${NGC_API_KEY}

# ==========================
# Service-Specific API Keys (Optional)
# Set these to use different API keys for individual services.
# If not set or empty, all services use NVIDIA_API_KEY as fallback.
# ==========================
# export APP_LLM_APIKEY=""
# export APP_EMBEDDINGS_APIKEY=""
# export APP_RANKING_APIKEY=""
# export APP_QUERYREWRITER_APIKEY=""
# export APP_FILTEREXPRESSIONGENERATOR_APIKEY=""
# export APP_VLM_APIKEY=""
# export SUMMARY_LLM_APIKEY=""
# export REFLECTION_LLM_APIKEY=""

# ==========================
# NVIDIA API Catalog Hosted NIM Endpoints
# ==========================
# All NIMs use NVIDIA-hosted API Catalog endpoints
# Leave SERVERURL empty to use NVIDIA API Catalog

# LLM - Response Generation
export APP_LLM_SERVERURL=""
export APP_LLM_MODELNAME="nvidia/llama-3.3-nemotron-super-49b-v1.5"

# Query Rewriter
export APP_QUERYREWRITER_SERVERURL=""
export APP_QUERYREWRITER_MODELNAME="nvidia/llama-3.3-nemotron-super-49b-v1.5"

# Filter Expression Generator
export APP_FILTEREXPRESSIONGENERATOR_SERVERURL=""
export APP_FILTEREXPRESSIONGENERATOR_MODELNAME="nvidia/llama-3.3-nemotron-super-49b-v1.5"

# Summary LLM
export SUMMARY_LLM="nvidia/llama-3.3-nemotron-super-49b-v1.5"
export SUMMARY_LLM_SERVERURL=""

# Reflection LLM
export REFLECTION_LLM="nvidia/llama-3.3-nemotron-super-49b-v1.5"
export REFLECTION_LLM_SERVERURL=""

# Embeddings - Use NVIDIA API Catalog
export APP_EMBEDDINGS_SERVERURL="https://integrate.api.nvidia.com/v1"
export APP_EMBEDDINGS_MODELNAME="nvidia/llama-3.2-nv-embedqa-1b-v2"

# Reranking - Use NVIDIA API Catalog
export APP_RANKING_SERVERURL=""
export APP_RANKING_MODELNAME="nvidia/llama-3.2-nv-rerankqa-1b-v2"

# ==========================
# Ingestion NIMs - Use NVIDIA API Catalog
# ==========================

# OCR
export OCR_HTTP_ENDPOINT="https://ai.api.nvidia.com/v1/cv/nvidia/nemoretriever-ocr"
export OCR_INFER_PROTOCOL="http"
export OCR_MODEL_NAME="scene_text_ensemble"

# Page Elements
export YOLOX_HTTP_ENDPOINT="https://ai.api.nvidia.com/v1/cv/nvidia/nemoretriever-page-elements-v3"
export YOLOX_INFER_PROTOCOL="http"

# Graphic Elements
export YOLOX_GRAPHIC_ELEMENTS_HTTP_ENDPOINT="https://ai.api.nvidia.com/v1/cv/nvidia/nemoretriever-graphic-elements-v1"
export YOLOX_GRAPHIC_ELEMENTS_INFER_PROTOCOL="http"

# Table Structure
export YOLOX_TABLE_STRUCTURE_HTTP_ENDPOINT="https://ai.api.nvidia.com/v1/cv/nvidia/nemoretriever-table-structure-v1"
export YOLOX_TABLE_STRUCTURE_INFER_PROTOCOL="http"

# ==========================
# cuVS Vector Database Configuration
# ==========================

# Vector DB GPU Configuration
# Use only 1 GPU for cuVS-accelerated Milvus
export VECTORSTORE_GPU_DEVICE_ID=0

# GPU-accelerated search and indexing
export APP_VECTORSTORE_ENABLEGPUSEARCH=True
export APP_VECTORSTORE_ENABLEGPUINDEX=True
export APP_VECTORSTORE_INDEXTYPE="GPU_CAGRA"

# ==========================
# Paths
# ==========================
export PROMPT_CONFIG_FILE=${PWD}/src/nvidia_rag/rag_server/prompt.yaml

# ==========================
# Performance Settings
# ==========================
# Accuracy profile for best results
# export APP_NVINGEST_ENABLEPDFSPLITTER=False
# export APP_NVINGEST_CHUNKSIZE=1024
# export APP_NVINGEST_CHUNKOVERLAP=150
# export ENABLE_RERANKER=True
# export VECTOR_DB_TOPK=100
